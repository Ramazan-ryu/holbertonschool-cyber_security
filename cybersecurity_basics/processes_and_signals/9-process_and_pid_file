#!/usr/bin/env bash

PIDFILE="/var/run/myscript.pid"

# Create PID file
echo $$ > "$PIDFILE"

# SIGTERM handler
term_handler() {
    echo "I hate the kill command"
    rm -f "$PIDFILE"
    exit 0
}

# SIGINT handler (Ctrl+C)
int_handler() {
    echo "Y U no love me?!"
}

# SIGQUIT handler
quit_handler() {
    rm -f "$PIDFILE"
    exit 0
}

# Trap signals
trap term_handler SIGTERM
trap int_handler SIGINT
trap quit_handler SIGQUIT

# Infinite loop
while true
do
    echo "To infinity and beyond"
    sleep 1
done
